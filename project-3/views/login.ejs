<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="bg-zinc-900 w-full h-screen text-white p-10">
        <h2 class="text-3xl mb-4">Login Your Account</h2>
        <form class="flex flex-wrap gap-4" action="/login" method="post">
            <input class="px-3 py-2 bg-zinc-600 rounded-md outline-none" type="email" placeholder="email" name="email">
            <input class="px-3 py-2 bg-zinc-600 rounded-md outline-none" type="password" placeholder="password"
            name="password">
            <input class="px-4 py-2 bg-green-600 rounded-lg" type="submit" value="Login">
        </form>
    </div>
</body>

</html>