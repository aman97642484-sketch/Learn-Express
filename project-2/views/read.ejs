<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="w-full bg-zinc-900 min-h-screen main p-10 text-white">
        <div class="nav mb-10">
            <a class="bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded" href="/">Back to Home</a>
        </div>
        <h1 class="text-3xl tracking-tighter mb-3">All Users</h1>
        <div class="users flex gap-5 flex-wrap">
            <% if(users.length> 0) { %>
                <% users.forEach(user=> { %>
                    <div class="user bg-zinc-800 w-68 p-4 rounded-lg">
                        <div class="img w-full h-58 bg-zinc-600 rounded-lg overflow-hidden">
                            <img class="w-full h-full object-cover" src="<%= user.imgUrl %>" alt="">
                        </div>
                        <h1 class="text-xl font-bold mt-3">
                            <%= user.name %>
                        </h1>
                        <h4 class="text-gray-400">
                            <%= user.email %>
                        </h4>
                        <div class="flex justify-between mt-3">
                            <a class="text-zinc-500" href="/edit/<%= user._id %>">Edit User</a>
                            <a class="text-red-500" href="/delete/<%= user._id %>">Delete User</a>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <h1 class="text-2xl text-gray-400">No Users Found</h1>
                            <% } %>
        </div>

    </div>
</body>

</html>