<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white pt-10 pl-10">
        <h1 class="text-3xl mb-4">Create Account</h1 class="text-3xl mb-4">
        <form action="/register" method="post">
            <input class="px-3 py-2 border-2 border-zonc-800 outline-none bg-transparent rounded-lg mr-2" type="text" placeholder="name" name="name">
            <input class="px-3 py-2 border-2 border-zonc-800 outline-none bg-transparent rounded-lg mr-2" type="text" placeholder="username" name="username">
            <input class="px-3 py-2 border-2 border-zonc-800 outline-none bg-transparent rounded-lg mr-2" type="password" placeholder="password" name="password">
            <input class="px-3 py-2 border-2 border-zonc-800 outline-none bg-transparent rounded-lg mr-2" type="email" placeholder="email" name="email">
            <input class="px-3 py-2 border-2 border-zonc-800 outline-none bg-transparent rounded-lg mr-2" type="number" placeholder="age" name="age">
            <input class="px-3 py-2 bg-blue-500 rounded-lg " type="submit" value="Create Account">
        </form>
    </div>
</body>

</html>