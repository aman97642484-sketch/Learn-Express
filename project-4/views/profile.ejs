<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white pt-10 pl-10">
        <div class="w-full px-4 flex justify-end">
            <a class="bg-red-400 px-3 py-2 rounded-md text-sm mb-4 inline-block" href="/logout">logout</a>
        </div>
        <h1 class="text-3xl"><span class="font-light">Hello</span>, <%= user.name %>👋 </h1>
        <h5>You can create a new post.</h5>
        <form class="mt-4" action="/post" method="post">
            <textarea class="p-3 rounded resize-none w-1/3 border-2  border-zinc-800"
                placeholder="What's in your mind ?" name="content"></textarea>
            <input class="block text-sm bg-blue-500 text-white px-4 py-2 rounded-md mt-2 w-40" type="submit"
                value="Create new post" name="">
        </form>

        <div class="posts mt-15">
            <h5 class="text-zinc-400">Your Posts</h5>
            <div class="postcontainer mt-5">
                <% user.posts.reverse().forEach(function(post){ %>
                    <div class="post bg-zinc-800 border-zinc-700 mb-4 border rounded-md w-1/3 p-3">
                        <h5 class="text-blue-400 mb-2">
                            <%= user.email %>
                        </h5>
                        <p class="text-sm tracking-tighter">
                            <%= post.content %>
                        </p>
                        <div class="btns flex mt-2 gap-3">
                            <a class="text-blue-500" href="">like</a>
                            <a class="text-zinc-700" href="">edit</a>
                        </div>
                    </div>
                    <% }) %>
            </div>
        </div>
    </div>
</body>

</html>