<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="main bg-zinc-900 h-screen w-screen">
        <h1 class="text-3xl font-bold text-center text-white pt-10">Task Manager</h1>

        <div class="form text-white  gap-4 p-10">
            <a href="/" class="mb-4 inline-block text-blue-400 hover:text-blue-300">Back to Tasks</a>
            <h2 class="text-2xl font-bold mb-4">
                <%= title %>
            </h2>
            <p class=" rounded-md mt-4 outline-none resize-none">
                <%= description %>
            </p>
        </div>
    </div>
</body>

</html>