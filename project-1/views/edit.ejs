<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="main bg-zinc-900 h-screen w-screen">
        <h1 class="text-3xl font-bold text-center text-white pt-10">Task Manager</h1>

        <div class="form text-white  gap-4 p-10">
            <a href="/" class="mb-4 inline-block text-blue-400 hover:text-blue-300">Back to Tasks</a>
            <form class="text flex flex-col flex-wrap" action="/edit" method="POST">
                <input class="bg-zinc-700 px-4 text-zinc-400 py-2 w-1/4 rounded-md outline-none border-solid" type="text" name="previous" disabled="true"
                    placeholder="PREVIOUS TITLE" value="<%= title %>">
                <input class="bg-zinc-700 px-4 mt-4 w-1/4 py-2 rounded-md outline-none border-solid" type="text" name="new" 
                    placeholder="ADD TITLE">
                <button
                    class="text-start mt-4 bg-yellow-500 hover:bg-yellow-600 text-white font-bold py-2 px-4 rounded w-42"
                    type="submit">Update Filename</button>
            </form>
        </div>
    </div>
</body>

</html>